# Supabase — already configured in .env.local for the existing auth setup.
# These are PUBLIC (exposed to the browser) and safe to ship.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Anthropic — used by /api/scan (Haiku verdict + Sonnet vision identify)
# and /api/listing (Haiku FB-listing copy). Server-side only.
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# eBay Browse API — used by /api/scan to look up sold/listed comps.
# Create an app at https://developer.ebay.com/my/keys then use the
# production "Cert ID" as the secret. Server-side only.
EBAY_CLIENT_ID=YourEbayAppID-Loot-PRD-...
EBAY_CLIENT_SECRET=PRD-...
